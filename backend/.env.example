APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trainingops?sslmode=disable

# REQUIRED outside test mode: must be at least 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

VAULT_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_PATH=./uploads
REPORTS_PATH=./reports

# Optional initial seed (used by seed command or startup bootstrap helper).
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeThisPassword123!A
